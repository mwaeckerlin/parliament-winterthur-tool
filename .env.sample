NEXTCLOUD_DB_PASSWORD=change_me_db_password
NEXTCLOUD_ADMIN_PASSWORD=change_me_admin_password

# Optional:
# COMPOSE_PROJECT_NAME=parlwin_dev
# NEXTCLOUD_HTTP_PORT=29824
# HOST=localhost:29824
# PROTOCOL=http
# WEBROOT=
# PARLWIN_REALTIME_WS_URL is auto-derived as ws(s)://<host>[<WEBROOT>]/ws/parlwin/
# and only needs to be set if Nextcloud is reachable under a different
# public origin than the configured HOST (e.g. behind an external CDN).
# PARLWIN_REALTIME_WS_URL=wss://cloud.example.com/ws/parlwin/
# PARLWIN_REALTIME_SECRET=change_me_realtime_secret
# PARLWIN_SYNC_SECTION_PARALLEL=6
# PARLWIN_SYNC_GESCHAEFTE_PARALLEL=10
# PARLWIN_SYNC_HTTP_CONNECT_TIMEOUT=8
# PARLWIN_SYNC_HTTP_TIMEOUT=25
# PARLWIN_SYNC_HTTP_LOW_SPEED_TIME=12
# PARLWIN_SYNC_HTTP_LOW_SPEED_LIMIT=1
