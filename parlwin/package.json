{
  "name": "parlwin",
  "version": "1.0.0",
  "license": "MIT",
  "description": "Nextcloud-Plugin für die Fraktionsarbeit im Winterthurer Parlament",
  "keywords": ["nextcloud", "parliament", "winterthur", "fraktion"],
  "private": true,
  "scripts": {
    "dev": "webpack --node-env development --config webpack.js --watch",
    "build": "webpack --node-env production --config webpack.js && npm run build:css",
    "build:css": "sass src/css/style.scss css/parlwin-style.css --no-source-map",
    "lint": "eslint src --ext .js,.vue",
    "test": "jest"
  },
  "dependencies": {
    "@nextcloud/axios": "^2.5.0",
    "@nextcloud/router": "^3.0.1",
    "@nextcloud/vue": "^8.22.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@nextcloud/eslint-config": "^8.4.1",
    "@nextcloud/webpack-vue-config": "^6.1.0",
    "babel-loader": "^10.0.0",
    "css-loader": "^7.1.2",
    "eslint": "^8.57.0",
    "eslint-plugin-vue": "^9.26.0",
    "sass": "^1.77.4",
    "sass-loader": "^16.0.2",
    "vue-loader": "^17.4.2",
    "webpack": "^5.93.0",
    "webpack-cli": "^6.0.1"
  }
}
